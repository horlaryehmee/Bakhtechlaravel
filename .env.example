API_PORT=4174
JWT_SECRET=change-this-long-random-secret
ADMIN_EMAIL=admin@bakhtech.com.ng
ADMIN_PASSWORD=ChangeMe123!

# Optional live/production settings
# Use DB_PATH or DB_DIR on a persistent disk/volume so admin changes survive deploys.
DB_PATH=./server/data/bakhtech.sqlite
UPLOAD_DIR=./public/uploads

# Leave empty when frontend and API are served from the same domain.
# Set this during build if the frontend is hosted separately from the API.
VITE_API_BASE_URL=

# Optional comma-separated allowed browser origins for the API.
CLIENT_ORIGIN=
