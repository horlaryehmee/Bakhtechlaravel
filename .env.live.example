APP_NAME="Bakhtech Solutions"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR_DOMAIN_HERE

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CPANEL_DATABASE_NAME
DB_USERNAME=CPANEL_DATABASE_USER
DB_PASSWORD=CPANEL_DATABASE_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.YOUR_DOMAIN_HERE

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=YOUR_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=YOUR_SMTP_USERNAME
MAIL_PASSWORD=YOUR_SMTP_PASSWORD
MAIL_FROM_ADDRESS=admin@YOUR_DOMAIN_HERE
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_USER_ID=me

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://YOUR_DOMAIN_HERE/booking/payment-callback
FLUTTERWAVE_WEBHOOK_SECRET=CHANGE_THIS_FLUTTERWAVE_WEBHOOK_HASH
FLUTTERWAVE_SECRET_KEY=CHANGE_THIS_FLUTTERWAVE_SECRET_KEY
FLUTTERWAVE_PUBLIC_KEY=CHANGE_THIS_FLUTTERWAVE_PUBLIC_KEY

ADMIN_EMAIL=admin@YOUR_DOMAIN_HERE
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
ADMIN_NAME="Bakhtech Admin"
API_TOKEN_SECRET=CHANGE_THIS_LONG_RANDOM_SECRET
FRONTEND_ORIGINS=https://YOUR_DOMAIN_HERE
VITE_API_BASE_URL=
