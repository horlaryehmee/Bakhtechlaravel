APP_NAME="Bakhtech Solutions"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR_DOMAIN_HERE

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CPANEL_DATABASE_NAME
DB_USERNAME=CPANEL_DATABASE_USER
DB_PASSWORD=CPANEL_DATABASE_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.YOUR_DOMAIN_HERE

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=admin@YOUR_DOMAIN_HERE
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@YOUR_DOMAIN_HERE
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
ADMIN_NAME="Bakhtech Admin"
API_TOKEN_SECRET=CHANGE_THIS_LONG_RANDOM_SECRET
FRONTEND_ORIGINS=https://YOUR_DOMAIN_HERE

